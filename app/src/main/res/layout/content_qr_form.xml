<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:background="@drawable/bg_card_surface"
        android:orientation="vertical">

        <TextView
            android:id="@+id/labelContentTypeField"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:labelFor="@id/textViewSelectedContentType"
            android:text="@string/content_type_label"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/contentTypeContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_input_surface"
            android:contentDescription="@string/pick_content_type_accessibility"
            android:gravity="center_vertical"
            android:minHeight="60dp"
            android:orientation="horizontal"
            android:padding="14dp">

            <TextView
                android:id="@+id/textViewSelectedContentType"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/default_content_type"
                android:textColor="@color/text_muted"
                android:textSize="14sp" />

            <Button
                android:id="@+id/buttonPickContentType"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:backgroundTint="@color/button_secondary_bg"
                android:contentDescription="@string/pick_content_type_accessibility"
                android:paddingHorizontal="18dp"
                android:text="@string/content_type_label"
                android:textAllCaps="false"
                android:textColor="@color/button_secondary_text" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/textInputContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/labelTextField"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:labelFor="@id/editTextText"
                android:text="@string/text_field_label"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/editTextText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:autofillHints=""
                android:background="@drawable/bg_input_surface"
                android:hint="@string/enter_text_for_qr_code"
                android:inputType="text"
                android:minHeight="56dp"
                android:paddingHorizontal="16dp"
                android:paddingVertical="14dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/wifiFieldsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/labelWifiSsidField"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:labelFor="@id/editTextWifiSsid"
                android:text="@string/wifi_ssid_label"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/editTextWifiSsid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"

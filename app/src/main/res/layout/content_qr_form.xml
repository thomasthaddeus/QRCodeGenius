<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:background="@drawable/bg_card_surface"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/text_field_label"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/editTextText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:autofillHints=""
            android:background="@drawable/bg_input_surface"
            android:hint="@string/enter_text_for_qr_code"
            android:inputType="text"
            android:minHeight="56dp"
            android:paddingHorizontal="16dp"
            android:paddingVertical="14dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/size_field_label"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/editTextSize"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:autofillHints=""
            android:background="@drawable/bg_input_surface"
            android:hint="@string/enter_size_hint"
            android:inputType="number"
            android:minHeight="56dp"
            android:paddingHorizontal="16dp"
            android:paddingVertical="14dp"
            android:text="@string/default_qr_size" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/save_format_label"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/saveFormatContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_input_surface"
            android:gravity="center_vertical"
            android:minHeight="60dp"
            android:orientation="horizontal"
            android:padding="14dp">

            <TextView
                android:id="@+id/textViewSelectedSaveFormat"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/default_save_format"
                android:textColor="@color/text_muted"
                android:textSize="14sp" />

            <Button
                android:id="@+id/buttonPickSaveFormat"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:backgroundTint="@color/button_secondary_bg"
                android:paddingHorizontal="18dp"
                android:text="@string/save_format_label"
                android:textAllCaps="false"
                android:textColor="@color/button_secondary_text" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/save_text_field_label"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/editTextSaveText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:autofillHints=""
            android:background="@drawable/bg_input_surface"
            android:hint="@string/enter_text_to_save_beneath_the_image"
            android:inputType="text"
            android:minHeight="56dp"
            android:paddingHorizontal="16dp"
            android:paddingVertical="14dp"
            android:text="@string/default_save_text" />

        <TextView
            android:id="@+id/textViewColorLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/color_picker_label"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/colorPickerContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_input_surface"
            android:gravity="center_vertical"
            android:minHeight="60dp"
            android:orientation="horizontal"
            android:padding="14dp">

            <View
                android:id="@+id/viewSelectedColor"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_color_swatch" />

            <TextView
                android:id="@+id/textViewSelectedColor"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:text="@string/default_qr_color"
                android:textColor="@color/text_muted"
                android:textSize="14sp" />

            <Button
                android:id="@+id/buttonPickColor"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:backgroundTint="@color/button_primary_bg"
                android:paddingHorizontal="18dp"
                android:text="@string/choose_color"
                android:textAllCaps="false"
                android:textColor="@color/button_primary_text" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/buttonGenerate"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:backgroundTint="@color/button_primary_bg"
                android:text="@string/generate_qr_code"
                android:textAllCaps="false"
                android:textColor="@color/button_primary_text" />

            <Button
                android:id="@+id/buttonSave"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:backgroundTint="@color/button_secondary_bg"
                android:text="@string/save_qr_code"
                android:textAllCaps="false"
                android:textColor="@color/button_secondary_text" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/buttonShare"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:backgroundTint="@color/button_secondary_bg"
                android:text="@string/share_qr_code"
                android:textAllCaps="false"
                android:textColor="@color/button_secondary_text" />

            <Button
                android:id="@+id/buttonViewSample"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:backgroundTint="@color/button_secondary_bg"
                android:text="@string/view_image_sample"
                android:textAllCaps="false"
                android:textColor="@color/button_secondary_text" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:background="@drawable/bg_preview_surface"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/preview_section_label"
            android:textColor="@color/preview_label_text"
            android:textSize="14sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/imageViewQRCode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:contentDescription="@string/image_description"
            android:visibility="gone" />
    </LinearLayout>
</merge>

                android:paddingHorizontal="16dp"
                android:paddingVertical="14dp" />

            <TextView
                android:id="@+id/labelWifiPasswordField"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:labelFor="@id/editTextWifiPassword"
                android:text="@string/wifi_password_label"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/editTextWifiPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:autofillHints=""
                android:background="@drawable/bg_input_surface"
                android:hint="@string/wifi_password_hint"
                android:inputType="textPassword"
                android:minHeight="56dp"
                android:paddingHorizontal="16dp"
                android:paddingVertical="14dp" />

            <TextView
                android:id="@+id/labelWifiSecurityField"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:labelFor="@id/textViewSelectedWifiSecurity"

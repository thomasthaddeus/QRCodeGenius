                android:minHeight="60dp"
                android:orientation="horizontal"
                android:padding="14dp">

                <TextView
                    android:id="@+id/textViewSelectedWifiSecurity"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/default_wifi_security"
                    android:textColor="@color/text_muted"
                    android:textSize="14sp" />

                <Button
                    android:id="@+id/buttonPickWifiSecurity"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:backgroundTint="@color/button_secondary_bg"
                    android:contentDescription="@string/pick_wifi_security_accessibility"
                    android:paddingHorizontal="18dp"
                    android:text="@string/wifi_security_label"
                    android:textAllCaps="false"
                    android:textColor="@color/button_secondary_text" />
            </LinearLayout>

            <TextView
                android:id="@+id/labelWifiHiddenField"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:labelFor="@id/textViewSelectedWifiHidden"
                android:text="@string/wifi_hidden_label"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/wifiHiddenContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input_surface"
                android:contentDescription="@string/pick_wifi_hidden_accessibility"
                android:gravity="center_vertical"
                android:minHeight="60dp"
                android:orientation="horizontal"
                android:padding="14dp">

                <TextView
                    android:id="@+id/textViewSelectedWifiHidden"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/default_wifi_hidden_label"
                    android:textColor="@color/text_muted"
                    android:textSize="14sp" />

                <Button
                    android:id="@+id/buttonPickWifiHidden"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:backgroundTint="@color/button_secondary_bg"
                    android:contentDescription="@string/pick_wifi_hidden_accessibility"
                    android:paddingHorizontal="18dp"
                    android:text="@string/wifi_hidden_label"
                    android:textAllCaps="false"
                android:textColor="@color/button_secondary_text" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/phoneFieldsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"

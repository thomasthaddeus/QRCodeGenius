                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/no_logo_selected"
                android:textColor="@color/text_muted"
                android:textSize="14sp" />

            <Button
                android:id="@+id/buttonClearLogo"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:layout_marginEnd="8dp"
                android:backgroundTint="@color/button_secondary_bg"
                android:text="@string/clear_logo"
                android:textAllCaps="false"
                android:textColor="@color/button_secondary_text"
                android:visibility="gone" />

            <Button
                android:id="@+id/buttonPickLogo"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:contentDescription="@string/pick_logo_accessibility"
                android:backgroundTint="@color/button_secondary_bg"
                android:paddingHorizontal="18dp"
                android:text="@string/choose_logo"
                android:textAllCaps="false"
                android:textColor="@color/button_secondary_text" />
        </LinearLayout>

        <TextView
            android:id="@+id/labelSaveTextField"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:labelFor="@id/editTextSaveText"
            android:text="@string/save_text_field_label"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/editTextSaveText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:autofillHints=""
            android:background="@drawable/bg_input_surface"
            android:hint="@string/enter_text_to_save_beneath_the_image"
            android:inputType="text"
            android:minHeight="56dp"
            android:paddingHorizontal="16dp"
            android:paddingVertical="14dp"
            android:text="@string/default_save_text" />

        <TextView
            android:id="@+id/textViewColorLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:labelFor="@id/textViewSelectedColor"
            android:text="@string/color_picker_label"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/colorPickerContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_input_surface"
            android:gravity="center_vertical"
            android:minHeight="60dp"
            android:orientation="horizontal"
            android:padding="14dp">

            <View
                android:id="@+id/viewSelectedColor"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:importantForAccessibility="no"
                android:background="@drawable/bg_color_swatch" />

            <TextView
                android:id="@+id/textViewSelectedColor"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:text="@string/default_qr_color"
                android:textColor="@color/text_muted"
                android:textSize="14sp" />

            <Button
                android:id="@+id/buttonPickColor"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:contentDescription="@string/pick_color_accessibility"
                android:backgroundTint="@color/button_primary_bg"
                android:paddingHorizontal="18dp"
                android:text="@string/choose_color"
                android:textAllCaps="false"
                android:textColor="@color/button_primary_text" />
        </LinearLayout>

        <TextView
            android:id="@+id/textViewBackgroundColorLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:labelFor="@id/textViewSelectedBackgroundColor"
            android:text="@string/background_color_picker_label"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/backgroundColorPickerContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_input_surface"
            android:gravity="center_vertical"
            android:minHeight="60dp"
            android:orientation="horizontal"
            android:padding="14dp">

            <View
                android:id="@+id/viewSelectedBackgroundColor"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:importantForAccessibility="no"
                android:background="@drawable/bg_color_swatch" />

            <TextView
                android:id="@+id/textViewSelectedBackgroundColor"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:text="@string/default_qr_background_color"
                android:textColor="@color/text_muted"
                android:textSize="14sp" />

            <Button
                android:id="@+id/buttonPickBackgroundColor"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:contentDescription="@string/pick_background_color_accessibility"
                android:backgroundTint="@color/button_secondary_bg"
                android:paddingHorizontal="18dp"
                android:text="@string/choose_color"
                android:textAllCaps="false"
                android:textColor="@color/button_secondary_text" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/buttonGenerate"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:contentDescription="@string/generate_button_accessibility"
                android:backgroundTint="@color/button_primary_bg"
                android:text="@string/generate_qr_code"
                android:textAllCaps="false"
                android:textColor="@color/button_primary_text" />

            <Button
                android:id="@+id/buttonSave"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:contentDescription="@string/save_button_accessibility"
                android:backgroundTint="@color/button_secondary_bg"
                android:text="@string/save_qr_code"
                android:textAllCaps="false"
                android:textColor="@color/button_secondary_text" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/buttonShare"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:contentDescription="@string/share_button_accessibility"
                android:backgroundTint="@color/button_secondary_bg"
                android:text="@string/share_qr_code"
                android:textAllCaps="false"
                android:textColor="@color/button_secondary_text" />

            <Button
                android:id="@+id/buttonViewSample"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:contentDescription="@string/sample_button_accessibility"
                android:backgroundTint="@color/button_secondary_bg"
                android:text="@string/view_image_sample"
                android:textAllCaps="false"
                android:textColor="@color/button_secondary_text" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:background="@drawable/bg_preview_surface"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/textViewPreviewLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:accessibilityHeading="true"
            android:text="@string/preview_section_label"
            android:textColor="@color/preview_label_text"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textViewPreviewStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:accessibilityLiveRegion="polite"
            android:text="@string/preview_unavailable"
            android:textColor="@color/text_secondary"
            android:textSize="14sp" />

        <ImageView
            android:id="@+id/imageViewQRCode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:contentDescription="@string/image_description"
            android:visibility="gone" />
    </LinearLayout>
</merge>

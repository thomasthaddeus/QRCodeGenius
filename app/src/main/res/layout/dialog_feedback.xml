<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:id="@+id/textViewFeedbackPrompt"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/feedback_dialog_message"
        android:textColor="@color/text_secondary"
        android:textSize="14sp" />

    <RatingBar
        android:id="@+id/ratingBarFeedback"
        style="?android:attr/ratingBarStyleIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:isIndicator="false"
        android:numStars="5"
        android:rating="4"
        android:stepSize="1" />

    <EditText
        android:id="@+id/editTextFeedbackNotes"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_input_surface"
        android:gravity="top|start"
        android:hint="@string/feedback_notes_hint"
        android:inputType="textCapSentences|textMultiLine"
        android:minLines="4"
        android:padding="14dp"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_secondary" />

</LinearLayout>
